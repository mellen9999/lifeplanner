data/
*.ics

# machine-specific mcp wiring (absolute paths). use .mcp.json.example as a template.
.mcp.json

# python venv + caches
.venv/
__pycache__/
.pytest_cache/
*.pyc
*.pyo

# atomic-write temp files
*.tmp

# editor / os cruft
.DS_Store
*.swp

# local caldav credentials — never commit
.caldav.json

# local operational backup script (host-specific)
backup.sh
